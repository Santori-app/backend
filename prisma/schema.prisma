// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "mysql"
}

model User {
  id             String   @id @default(uuid())
  name           String
  email          String?  @unique
  username       String   @unique
  phone          String?  @db.VarChar(20)
  password       String?

  memberships    CompanyUser[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Company {
  id        String   @id @default(uuid())

  name      String
  slug      String   @unique
  active    Boolean  @default(true)

  legalName String?  @db.VarChar(255)
  cnpj      String?  @unique @db.VarChar(14)

  groupId   String?
  group     Group?  @relation(fields: [groupId], references: [id])

  users     CompanyUser[]
  customers CompanyCustomer[]
  offerings Offering[]
  plans     Plan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}


model CompanyUser {
  id        String   @id @default(uuid())

  userId    String
  companyId String

  role      Role
  active    Boolean  @default(true)
  verified  Boolean  @default(false)

  user      User     @relation(fields: [userId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  deletedAt DateTime?

  @@unique([userId, companyId])
}

model Offering {
  id                String   @id @default(uuid())
  companyId         String

  name              String
  description       String?
  type              OfferingType
  
  price             Int        // em centavos
  timeToExecute     Int?       // minutos

  commissionPercent Int?        // 1 a 100

  active            Boolean    @default(true)

  planServices      PlanService[]

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  company           Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model Plan {
  id           String   @id @default(uuid())
  companyId    String

  name         String
  description  String?
  price        Int
  billingCycle PlanCycle
  active       Boolean @default(true)

  planServices    PlanService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model PlanService {
  id          String   @id @default(uuid())
  planId      String
  offeringId  String
  quantity    Int

  plan        Plan     @relation(fields: [planId], references: [id])
  offering    Offering @relation(fields: [offeringId], references: [id])

  @@unique([planId, offeringId]) // impede duplicar o mesmo serviço
}
model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique
  phone     String?  @db.VarChar(20)
  birthDate DateTime?
  active    Boolean  @default(true)

  companies CompanyCustomer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyCustomer {
  id          String   @id @default(uuid())

  customerId  String
  companyId   String

  firstVisit  DateTime @default(now())
  lastVisit   DateTime?
  active      Boolean  @default(true)

  customer    Customer @relation(fields: [customerId], references: [id])
  company     Company  @relation(fields: [companyId], references: [id])

  @@unique([customerId, companyId])
}

model Group {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique

  companies Company[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  STAFF       //? Agente do sistema (Criadores do sistema)
  SUPER_ADMIN //? Gerencia a Franquia
  OWNER       //? Único por Company e é o responsável principal
  ADMIN       //? Administrador com todas as funcionalidades do sistema disponível
  MANAGER     //? Gerente da barbearia caso exista
  BARBER      //? Barbeiro responsável por cortar o cabelo
  RECEPTION   //? Recepcionista da barbearia caso exista
}

enum PlanCycle {
  MONTHLY
  YEARLY
  WEEKLY
}

enum OfferingType {
  SERVICE
  PRODUCT
}